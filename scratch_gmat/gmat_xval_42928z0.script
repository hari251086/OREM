Report Repxval RunID SC11.ElapsedSecs SC11.Earth.RadApo SC11.Earth.ECC SC11.Earth.SMA;
Propagate Propxval(SC11) {SC11.ElapsedSecs = 604800};
Report Repxval RunID SC11.ElapsedSecs SC11.Earth.RadApo SC11.Earth.ECC SC11.Earth.SMA;

GMAT RunID = 12;
